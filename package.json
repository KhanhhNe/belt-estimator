{
	"name": "belt-estimator",
	"version": "1.0.0",
	"description": "Express.js starter app",
	"main": "src/server.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"start": "node src/server.js",
		"dev": "nodemon src/server.js",
		"cf:dev": "wrangler dev",
		"cf:deploy": "wrangler deploy",
		"cf:secret:url": "wrangler secret put TURSO_DATABASE_URL",
		"cf:secret:token": "wrangler secret put TURSO_AUTH_TOKEN",
		"attendance:push": "node scripts/push-attendance-dates.js",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"@libsql/client": "^0.17.3",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.1",
		"drizzle-kit": "^0.31.10",
		"nodemon": "^3.1.14",
		"typescript": "^6.0.3",
		"wrangler": "^4.95.0"
	}
}
